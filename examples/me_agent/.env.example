FOUNDRY_AGENT_PUBLIC_URL=http://127.0.0.1:8085
FOUNDRY_BOOTSTRAP_DELIVERY=push
FOUNDRY_DISCOVERY_CLAIM_TOKEN=
FOUNDRY_DEVELOPER_IDENTITY_JSON=
FOUNDRY_NETWORK_ZONE=EXTERNAL
FOUNDRY_HEARTBEAT_SECONDS=30
FOUNDRY_DISCOVERY_TAGS=me_agent,personal,self_hosted
FOUNDRY_WORKSPACE_FEATURES=chat
FOUNDRY_INTERACTION_MODES=chat
FOUNDRY_TERMINAL_PROVIDER=none
