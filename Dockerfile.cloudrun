# --- Stage 1: build the SDK and agent packages --------------------------------
FROM python:3.12-slim AS builder

WORKDIR /build

# Copy only package metadata and source needed for installation. Keep
# agent_space out of this stage so prompt/config changes do not invalidate pip.
COPY packages/python-sdk/pyproject.toml packages/python-sdk/README.md /build/packages/python-sdk/
COPY packages/python-sdk/src /build/packages/python-sdk/src
COPY examples/me_agent/pyproject.toml examples/me_agent/README.md /build/examples/me_agent/
COPY examples/me_agent/src /build/examples/me_agent/src

# Install both together so pip resolves the local ccfoundry-agent-kit dependency
# uvicorn is added explicitly as it's the ASGI server (not in SDK deps)
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install \
    /build/packages/python-sdk \
    /build/examples/me_agent \
    "uvicorn[standard]>=0.30,<1.0"

# --- Stage 2: production image ------------------------------------------------
FROM python:3.12-slim

LABEL org.opencontainers.image.source="https://github.com/ic-star-tech/ccfoundry-agent-kit"
LABEL org.opencontainers.image.description="CCFoundry Agent — Cloud Run deployment"

WORKDIR /app

# Copy installed packages from builder (system site-packages)
COPY --from=builder /usr/local/lib/python3.12/site-packages /usr/local/lib/python3.12/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

# Copy the agent application source (needed for uvicorn --app-dir)
COPY examples/me_agent/src /app/src

# Copy agent_space (SOUL.md, config.yaml, skills, etc.)
COPY examples/me_agent/agent_space /app/agent_space

# Create workspace directory
RUN mkdir -p /app/workspace

# Cloud Run injects PORT env var (default 8080)
ENV PORT=8080
ENV PYTHONUNBUFFERED=1
ENV AGENT_DEPLOY_MODE=cloud_run
ENV ME_AGENT_BASE_DIR=/app

EXPOSE 8080

CMD ["python", "-m", "uvicorn", "me_agent_example.app:app", \
     "--app-dir", "/app/src", \
     "--host", "0.0.0.0", \
     "--port", "8080"]
